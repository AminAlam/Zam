# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=zam
DB_PASSWORD=change_this_secure_password
DB_NAME=zam_db

# Telegram Bot Tokens
ADMIN_TELEGRAM_BOT=your_admin_bot_token
SUGGESTIONS_TELEGRAM_BOT=your_suggestions_bot_token

# Telegram Channel/Chat IDs
MAIN_CHANNEL_CHAT_ID=your_main_channel_id
ADMIN_CHAT_ID=your_admin_chat_id
SUGGESTIONS_CHAT_ID=your_suggestions_chat_id

# Channel Info
CHANNEL_NAME=@YourChannelName

# Admin Users (comma-separated usernames without @)
ADMIN_IDS=admin1,admin2,admin3

# Tweet Capture Method: "scrapebadger" (default) or "screenshot" (legacy Chromium)
ZAM_CAPTURE_METHOD=scrapebadger

# ScrapeBadger API key (required when ZAM_CAPTURE_METHOD=scrapebadger)
# Get one at https://scrapebadger.com
SCRAPEBADGER_API_KEY=sb_live_your_api_key_here

# Twitter/X auth token (optional, helps yt-dlp download age-restricted/protected videos)
# Get from browser DevTools > Application > Cookies > x.com > auth_token
# AUTH_TOKEN=your_twitter_auth_token
